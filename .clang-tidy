---
Checks: >
  -bugprone-*,
  -cert-*,
  -clang-analyzer-*,
  -cppcoreguidelines-*,
  -misc-*,
  -modernize-*,
  -performance-*,
  -readability-braces-around-statements,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-named-parameter
WarningsAsErrors: ''
HeaderFilterRegex: 'main/.*'
ExcludeHeaderFilterRegex: 'main/cJSON\.(c|h)'
FormatStyle: file
---
